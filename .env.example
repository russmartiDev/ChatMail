# ─────────────────────────────────────────────
#  MailMind Backend — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
# Default port used in development; Cloud Run overrides PORT to 8080 by
# setting the environment variable when deploying. The application already
# falls back to 8080 if PORT is not supplied.
PORT=3000

# JWT Secret — use any long random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Anthropic API Key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Gemini (Google) API Key – used for embedding and other AI calls
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your-google-generative-ai-key

# Google OAuth Credentials
# Get from: https://console.cloud.google.com
# Create OAuth 2.0 Web Client credentials
# Add http://localhost:3000/auth/gmail/callback as Authorized redirect URI
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/gmail/callback

# CORS — your Expo dev client URL (update if needed)
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081,exp://192.168.1.100:8081

# Required: point to a Postgres database (Prisma, Supabase, Heroku, etc.)
# Example:
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
#
# SQLite is no longer supported; the app will refuse to start without this value.

# -----------------------------------------------------------------------------
# Cloud Run / CI notes
# -----------------------------------------------------------------------------
# When deploying to Google Cloud Run you don't check in a .env file; instead set
# environment variables on the service (via the Cloud Console, gcloud CLI, or
# Cloud Build deployment step). Cloud Run will make them available on
# process.env just like dotenv does in development.
#
# Example deployment command:
#   gcloud run deploy mailmind-backend \
#       --image gcr.io/$PROJECT_ID/mailmind-backend \
#       --region us-central1 \
#       --platform managed \
#       --allow-unauthenticated \
#       --set-env-vars "PORT=8080,JWT_SECRET=$JWT_SECRET,ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY,GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID,GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET,GOOGLE_REDIRECT_URI=$GOOGLE_REDIRECT_URI,ALLOWED_ORIGINS=$ALLOWED_ORIGINS,DATABASE_URL=$DATABASE_URL"
#
# In a Cloud Build pipeline you can store sensitive values in Secret Manager and
# reference them with substitutions. See cloudbuild.yaml below for an example.
# -----------------------------------------------------------------------------
